{
  "name": "napplet",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev:site": "turbo run dev --filter=@napplet/web --filter=@napplet/docs",
    "test": "turbo run test:unit",
    "test:unit": "turbo run test:unit",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "version-packages": "changeset version && node scripts/sync-jsr-versions.mjs",
    "publish-packages": "turbo run build && pnpm publish -r --access public --no-git-checks",
    "publish-jsr": "node scripts/sync-jsr-versions.mjs && pnpm -r --filter='./packages/*' exec npx jsr publish --allow-slow-types --allow-dirty"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "nostr-tools": "^2.23.3",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.8.0"
}
