{
  "name": "@napplet/shim",
  "version": "0.26.7",
  "description": "Napplet SDK — subscribe, publish, query, emit, on, nappStorage for Nostr-native iframe applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./prelude": {
      "types": "./dist/prelude.d.ts",
      "import": "./dist/prelude.js",
      "browser": "./dist/prelude.global.js"
    },
    "./prelude.global": {
      "default": "./dist/prelude.global.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napplet/core": "workspace:*",
    "@napplet/nap": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandwichfarm/napplet.git",
    "directory": "packages/shim"
  },
  "keywords": [
    "nostr",
    "napplet",
    "iframe",
    "sdk",
    "nip-01"
  ]
}
