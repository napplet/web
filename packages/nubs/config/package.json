{
  "name": "@napplet/nub-config",
  "version": "0.3.0",
  "description": "[DEPRECATED] Use @napplet/nub/config instead. NUB-CONFIG message types and shim methods for per-napplet declarative configuration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napplet/nub": "workspace:*"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "json-schema-to-ts": "^3.1.1"
  },
  "peerDependenciesMeta": {
    "json-schema-to-ts": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandwichfarm/napplet.git",
    "directory": "packages/nubs/config"
  },
  "keywords": [
    "nostr",
    "napplet",
    "nub",
    "config"
  ]
}
