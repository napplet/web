{
  "name": "@napplet/vite-plugin",
  "version": "0.3.0",
  "description": "Vite plugin for napplet development — injects aggregate hash meta tag during dev and optionally generates NIP-5A manifest at build time for local testing",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "nostr-tools": "^2.23.3"
  },
  "devDependencies": {
    "@napplet/nub": "workspace:*",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.15.0",
    "vite": "^6.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "echo 'no unit tests'"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandwichfarm/napplet.git",
    "directory": "packages/vite-plugin"
  },
  "keywords": [
    "nostr",
    "napplet",
    "vite",
    "plugin",
    "nip-5a",
    "manifest"
  ]
}
